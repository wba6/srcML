{
  "version": 8,
  "include": [
    "CMakeBasePresets.json"
  ],
  "configurePresets": [
    {
      "name": "ci-msvc",
      "displayName": "MSVC",
      "description": "Default build options for MSVC",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
      "toolchainFile": "toolchain-msvc.cmake",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "cl",
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_FLAGS": "/Wall /D_CRT_SECURE_NO_WARNINGS /D_CRT_NONSTDC_NO_WARNINGS /wd4068 /wd4514 /wd4710 /wd4820 /wd5039 /wd4711 /wd4706 /wd4625 /wd4626 /wd5026 /wd5027 /wd4668 /wd4868 /wd4371 /wd4623 /wd5045 ",
        "SRCML_GLOBAL_COMPILE_OPTIONS": "/wd4355;/wd4866;/wd5204;/wd5264;/wd4577",
        "SRCML_GLOBAL_LINK_OPTIONS": "",
        "SRCML_ANTLR_DISABLED_WARNINGS": "/wd5267;/wd4242;/wd4244;/wd4267;/wd4355;/wd4365;/wd4477;/wd4530;/wd4577;/wd4100",
        "SRCML_PARSER_DISABLED_WARNINGS": "/wd4267;/wd4365;/wd4459;/wd4530;/wd4577;/wd4701;/wd5262;/wd5264",
        "SRCML_LIBSRCML_COMPILE_FLAGS": "/Zi",
        "SRCML_LIBSRCML_SHARED_LINK_FLAGS_RELEASE": "/DEBUG /OPT:REF /OPT:ICF",
        "SRCML_LIBSRCML_STATIC_LINK_FLAGS_RELEASE": "/LTCG:OFF",
        "SRCML_CLIENT_COMPILE_FLAGS": "/wd4355;/wd5204",
        "SRCML_CLIENT_LINK_FLAGS": "",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded"
      }
    }
  ],
  "buildPresets" : [
    {
      "name": "ci-msvc-only",
      "displayName": "Ubuntu only",
      "description": "Restrict to Ubuntu",
      "hidden": true,
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
      "configurePreset": "ci-msvc"
    },
    {
      "name": "ci-msvc",
      "inherits": ["ci-msvc-only"],
      "configuration": "Release"
    },
    {
      "name": "ci-clean-install-msvc3",
      "inherits": ["ci-msvc-only", "ci-clean-install"]
    },
    {
      "name": "ci-install-package-msvc",
      "inherits": ["ci-install-package", "ci-msvc-only"]
    },
    {
      "name": "ci-test-client-msvc",
      "inherits": ["ci-test-client", "ci-msvc-only"]
    },
    {
      "name": "ci-test-libsrcml-msvc",
      "inherits": ["ci-test-libsrcml", "ci-msvc-only"]
    },
    {
      "name": "ci-test-parser-msvc",
      "inherits": ["ci-test-parser", "ci-msvc-only"]
    }
  ],
  "packagePresets": [
    {
      "name": "ci-msvc-only",
      "hidden": true,
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
      "configurePreset": "ci-msvc"
    },
    {
      "name": "ci-msvc",
      "generators": [ "INNOSETUP", "NuGet", "ZIP" ],
      "inherits": ["ci-msvc-only", "ci-base"]
    },
    {
      "name": "ci-msvc-wix",
      "generators": [ "WIX", "ZIP" ],
      "inherits": ["ci-msvc-only", "ci-base"]
    },
    {
      "name": "ci-msvc-inno",
      "generators": [ "INNOSETUP", "ZIP" ],
      "inherits": ["ci-msvc-only", "ci-base"]
    },
    {
      "name": "ci-msvc-nuget",
      "generators": [ "NuGet", "ZIP" ],
      "inherits": ["ci-msvc-only", "ci-base"]
    }
  ],
  "testPresets": [
  ],
  "workflowPresets": [
    {
      "name": "ci-msvc",
      "steps": [
        { "type": "configure", "name": "ci-msvc" },
        { "type": "build",     "name": "ci-msvc" },
        { "type": "package",   "name": "ci-msvc" }
      ]
    }
  ]
}
